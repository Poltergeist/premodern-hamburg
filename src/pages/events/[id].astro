---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEventById, events } from '../../data/events';

export async function getStaticPaths() {
  return events.map(event => ({
    params: { id: event.id },
  }));
}

const { id } = Astro.params;
const event = getEventById(id);

if (!event) {
  return Astro.redirect('/404');
}
---

<BaseLayout title={event.name}>
  <div class="event-detail">
    <div class="breadcrumb">
      <a href="/">← Zurück zu allen Events</a>
    </div>

    <div class="event-hero card">
      <div class="event-status-bar">
        <span class="status-badge {event.status}">
          {event.status === 'upcoming' ? '📅 Upcoming' : event.status === 'completed' ? '✓ Abgeschlossen' : '❌ Abgesagt'}
        </span>
        <span class="category-badge">{event.category}</span>
      </div>

      <h1>{event.name}</h1>
      
      <div class="event-meta">
        <div class="meta-item large">
          <span class="meta-icon">📅</span>
          <div>
            <div class="meta-label">Datum & Zeit</div>
            <div class="meta-value">{event.date}</div>
          </div>
        </div>

        <div class="meta-item large">
          <span class="meta-icon">📍</span>
          <div>
            <div class="meta-label">Location</div>
            <div class="meta-value">{event.location.name}</div>
            <div class="meta-subtext">{event.location.address}</div>
            {event.location.url && (
              <a href={event.location.url} target="_blank" rel="noopener" class="location-link">
                Webseite →
              </a>
            )}
          </div>
        </div>
      </div>
    </div>

    <div class="content-grid">
      <div class="main-content">
        <div class="card">
          <h2>📝 Über das Event</h2>
          <p class="description">{event.description}</p>
        </div>

        <div class="card">
          <h2>🎮 Format & Regeln</h2>
          <div class="format-info">
            <div class="info-item">
              <span class="info-label">Format:</span>
              <span class="info-value">{event.format}</span>
            </div>
            <div class="format-description">
              <p>
                PreModern ist ein Eternal-Format für Magic: The Gathering, das Karten von 1995 bis 2003 umfasst 
                (4th Edition bis Scourge). Erlebe die Nostalgie klassischer Magic-Karten ohne die Power 9!
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="sidebar">
        { event.status === 'upcoming' && (
        <div class="card info-card">
          <h3>💰 Teilnahme</h3>
          <div class="info-grid">
            {event.entryFee && (
              <div class="info-row">
                <span class="info-icon">💵</span>
                <div>
                  <div class="info-label">Entry Fee</div>
                  <div class="info-value">{event.entryFee}</div>
                </div>
              </div>
            )}
            
            {event.prizes && (
              <div class="info-row">
                <span class="info-icon">🏆</span>
                <div>
                  <div class="info-label">Preise</div>
                  <div class="info-value">{event.prizes}</div>
                </div>
              </div>
            )}
          </div>

          {event.registrationLink && (
            <a href={event.registrationLink} class="btn" style="margin-top: 1.5rem; width: 100%;">
              Jetzt anmelden
            </a>
          )}
        </div>
        )}

        <div class="card info-card">
          <h3>ℹ️ Wichtige Infos</h3>
          <ul class="info-list">
            <li>Bringt eure eigenen Decks mit</li>
            <li>Leidecks sind verfügbar</li>
            <li>Freundliche Atmosphäre für Anfänger</li>
            <li>Snacks & Getränke verfügbar</li>
          </ul>
        </div>

      </div>
    </div>
  </div>

  <style>
    .event-detail {
      max-width: 1200px;
      margin: 0 auto;
    }

    .breadcrumb {
      margin-bottom: 2rem;
    }

    .breadcrumb a {
      color: var(--color-text-muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .breadcrumb a:hover {
      color: var(--color-blue);
    }

    .event-hero {
      margin-bottom: 2rem;
      padding: 2.5rem;
    }

    .event-status-bar {
      display: flex;
      gap: 1rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }

    .status-badge {
      padding: 0.5rem 1rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.9rem;
    }

    .status-badge.upcoming {
      background: rgba(63, 185, 80, 0.1);
      color: var(--color-green);
      border: 1px solid var(--color-green);
    }

    .status-badge.completed {
      background: rgba(139, 148, 158, 0.1);
      color: var(--color-text-muted);
      border: 1px solid var(--color-border);
    }

    .category-badge {
      padding: 0.5rem 1rem;
      border-radius: 8px;
      background: var(--color-medium-gray);
      color: var(--color-text-muted);
      font-size: 0.9rem;
      border: 1px solid var(--color-border);
    }

    .event-hero h1 {
      margin-bottom: 2rem;
      background: var(--gradient-magic);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .event-meta {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
    }

    .meta-item {
      display: flex;
      gap: 1rem;
      align-items: start;
    }

    .meta-icon {
      font-size: 2rem;
    }

    .meta-label {
      font-size: 0.85rem;
      color: var(--color-text-muted);
      margin-bottom: 0.25rem;
    }

    .meta-value {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--color-text);
    }

    .meta-subtext {
      font-size: 0.9rem;
      color: var(--color-text-muted);
      margin-top: 0.25rem;
    }

    .location-link {
      display: inline-block;
      margin-top: 0.5rem;
      color: var(--color-blue);
      text-decoration: none;
      font-size: 0.9rem;
    }

    .location-link:hover {
      text-decoration: underline;
    }

    .content-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    @media (min-width: 968px) {
      .content-grid {
        grid-template-columns: 2fr 1fr;
      }
    }

    .main-content {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .description {
      color: var(--color-text);
      line-height: 1.8;
      font-size: 1.1rem;
    }

    .format-info {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .info-item {
      display: flex;
      gap: 0.5rem;
      padding: 1rem;
      background: var(--color-medium-gray);
      border-radius: 8px;
      border: 1px solid var(--color-border);
    }

    .info-label {
      color: var(--color-text-muted);
      font-weight: 600;
    }

    .info-value {
      color: var(--color-text);
    }

    .format-description {
      color: var(--color-text-muted);
      line-height: 1.6;
    }

    .info-card {
      padding: 1.5rem;
    }

    .info-card h3 {
      margin-bottom: 1.5rem;
      font-size: 1.2rem;
    }

    .info-grid {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .info-row {
      display: flex;
      gap: 1rem;
      align-items: start;
    }

    .info-icon {
      font-size: 1.5rem;
    }

    .info-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .info-list li {
      padding-left: 1.5rem;
      position: relative;
      color: var(--color-text-muted);
    }

    .info-list li::before {
      content: '✓';
      position: absolute;
      left: 0;
      color: var(--color-green);
      font-weight: bold;
    }
  </style>
</BaseLayout>
